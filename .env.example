# WebSafe — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to source control.
#
# ─────────────────────────────────────────────────────────
# REQUIRED for production — all are optional for dev
# ─────────────────────────────────────────────────────────

# Google Safe Browsing v4 API key
# Get free key: https://developers.google.com/safe-browsing/v4/get-started
# Free tier: unlimited (non-commercial)
GSB_KEY=

# VirusTotal Public API key
# Sign up: https://www.virustotal.com/gui/join-us
# Free tier: ~500 req/day, 4 req/min
VT_KEY=

# urlscan.io API key
# Sign up: https://urlscan.io/user/signup
# Free tier: ~5 000 scans/day  (unlisted scans)
URLSCAN_KEY=

# CheckPhish API key (by Bolster)
# Sign up: https://developers.checkphish.ai/
# Free tier: ~250 scans/month
CHECKPHISH_KEY=

# Anthropic API key — for the in-app chat assistant
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────
# Optional server config
# ─────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Comma-separated list of allowed origins for CORS
# Example: https://websafe.yourdomain.com,https://www.websafe.yourdomain.com
ALLOWED_ORIGINS=
